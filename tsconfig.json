{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "src": [
        "src/*"
      ],
      "@fixtures*": [
        "src/__fixtures__",
        "src/__fixtures__*"
      ]
    },
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ],
    "outDir": "./dist/darlal-switcher-plus/tsc-output",
    "noEmit": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2023",
    "allowJs": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "lib": [
      "ES2023",
      "DOM"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules/*",
    "src/types",
    "dist"
  ]
}
